@startuml
title Sequence Diagram - Aggiunta carta ad album

actor Utente

participant "ConsoleView" as View
participant "UserController" as Controller
participant "UserFacade" as Facade
participant "CatalogService" as CatalogService
participant "CollectionService" as CollectionService
participant "Album" as Album
participant "UserCard" as UserCard

Utente -> View : seleziona carta e album
View -> Controller : richiediAggiuntaCarta(nomeCarta, nomeAlbum, nota)
Controller -> Facade : aggiungiCarta(user, card, album, nota)

Facade -> CatalogService : findCardByName(nomeCarta)
CatalogService --> Facade : card

Facade -> CollectionService : addCardToAlbum(user, card, album, nota)
CollectionService -> UserCard : new UserCard(card, nota)
CollectionService -> Album : addCard(userCard)

Album --> CollectionService : carta aggiunta
CollectionService --> Facade : operazione completata
Facade --> Controller : conferma
Controller --> View : mostra conferma
View --> Utente : carta aggiunta all'album

@enduml
